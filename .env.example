# ============================================
# TutAR NotebookLM POC — Environment Variables
# 
# Create a .env file with these values
# ============================================

# Google Gemini API Key (for AI lesson plan generation)
# Get from: https://aistudio.google.com
GEMINI_API_KEY=AIza_your_key_here

# Pinecone API Key (for vector storage)
# Get from: https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_key_here

# Pinecone Index Name
PINECONE_INDEX=tutar-textbooks

# Supabase Project URL
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon public key (NOT service_role key)
SUPABASE_ANON_KEY=eyJ_your_anon_key_here

# Supabase service_role key (for backend admin operations)
# IMPORTANT: keep this secret, only use server-side
SUPABASE_SERVICE_KEY=eyJ_your_service_role_key_here

# Server port
PORT=3000
